{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openscientist.local/witsoc/handoff.schema.json",
  "title": "Witsoc Explorer to Generator Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "state",
    "problem_profile",
    "problem_status",
    "source_citations",
    "solved_problem_map",
    "ontology_map",
    "theorem_candidates",
    "rejected_theorem_candidates",
    "backward_chaining",
    "falsification_pass",
    "obstructions",
    "barrier_map",
    "open_product_target",
    "conjectures",
    "proof_objects",
    "search_budget",
    "proof_compression",
    "target",
    "artifact_target",
    "sketches",
    "selected_sketch_id",
    "obligation_graph",
    "external_facts",
    "external_verifications",
    "mutation_tracker",
    "target_freeze",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "task_kind": {
      "type": "string",
      "enum": ["answer", "prove", "disprove", "prove_or_disprove", "solve", "deep_research", "wit_generation", "lean_generation", "repair", "audit"]
    },
    "user_intent": { "type": "string", "minLength": 1 },
    "state": {
      "type": "string",
      "enum": [
        "INTAKE",
        "EXPLORE",
        "HANDOFF_READY",
        "GENERATE_WIT",
        "CHECK_WIT",
        "BUILD_CONTEXT",
        "SEMANTIC_REVIEW",
        "RECEIPT",
        "OPTIONAL_LEAN",
        "REPAIR_WIT",
        "REPAIR_LEAN",
        "REPORT"
      ]
    },
    "problem_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_types", "difficulty", "proof_styles", "known_theorem_density", "search_implications"],
      "properties": {
        "object_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["algebra", "combinatorics", "geometry", "graph_theory", "number_theory", "analysis", "logic", "topology", "probability", "algorithms"]
          }
        },
        "difficulty": { "type": "string", "enum": ["D1", "D2", "D3", "D4", "D5"] },
        "proof_styles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["constructive", "extremal", "induction", "contradiction", "invariant", "probabilistic", "algebraic", "geometric", "analytic", "computational"]
          }
        },
        "known_theorem_density": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "search_implications": { "type": "array", "items": { "type": "string" } }
      }
    },
    "problem_status": {
      "type": "string",
      "enum": ["SOLVED", "ROUTINE", "OPEN", "UNSOLVED", "PARTIAL", "AMBIGUOUS", "UNCONFIRMED", "FALSE", "UNDER_SPECIFIED", "ALREADY_FORMALIZABLE"]
    },
    "source_citations": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_citation" }
    },
    "solved_problem_map": {
      "type": "object",
      "additionalProperties": false,
      "required": ["literature_anchor", "canonical_proof_landscape", "target_domain", "library_domain", "domain_alignment", "boundary_checks", "premise_minimization"],
      "properties": {
        "literature_anchor": { "type": "string" },
        "canonical_proof_landscape": { "type": "array", "items": { "type": "string" } },
        "target_domain": { "type": "string" },
        "library_domain": { "type": "string" },
        "domain_alignment": { "type": "string", "enum": ["exact", "narrower", "broader", "mismatch", "unknown", "not_applicable"] },
        "boundary_checks": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "premise_minimization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["direct_definition_unfolding", "weakest_standard_tool", "avoided_heavy_machinery"],
          "properties": {
            "direct_definition_unfolding": { "type": "string" },
            "weakest_standard_tool": { "type": "string" },
            "avoided_heavy_machinery": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "ontology_map": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_structure", "features", "theorem_families", "canonical_encodings", "search_queries"],
      "properties": {
        "primary_structure": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "theorem_families": { "type": "array", "items": { "type": "string" } },
        "canonical_encodings": { "type": "array", "items": { "type": "string" } },
        "search_queries": { "type": "array", "items": { "type": "string" } }
      }
    },
    "theorem_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/theorem_candidate" }
    },
    "rejected_theorem_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/rejected_theorem_candidate" }
    },
    "backward_chaining": {
      "type": "array",
      "items": { "$ref": "#/$defs/backward_goal" }
    },
    "falsification_pass": {
      "type": "array",
      "items": { "$ref": "#/$defs/falsification_layer" }
    },
    "obstructions": {
      "type": "array",
      "items": { "$ref": "#/$defs/obstruction" }
    },
    "barrier_map": {
      "type": "array",
      "items": { "$ref": "#/$defs/barrier" }
    },
    "open_product_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "statement", "why_this_product", "boundary"],
      "properties": {
        "kind": { "type": "string", "enum": ["finite_counterexample", "obstruction_lemma", "conditional_step", "not_applicable"] },
        "statement": { "type": "string" },
        "why_this_product": { "type": "string" },
        "boundary": { "type": "string" }
      }
    },
    "conjectures": {
      "type": "array",
      "items": { "$ref": "#/$defs/conjecture" }
    },
    "proof_objects": {
      "type": "array",
      "items": { "$ref": "#/$defs/proof_object" }
    },
    "search_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["time_budget", "attempt_budget", "computation_budget", "stop_conditions"],
      "properties": {
        "time_budget": { "type": "string" },
        "attempt_budget": { "type": "integer", "minimum": 0 },
        "computation_budget": { "type": "string" },
        "stop_conditions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "proof_compression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_sketch_id", "compression_goal", "removed_obligations", "kept_obligations", "target_fidelity_preserved", "risk"],
      "properties": {
        "selected_sketch_id": { "type": "string" },
        "compression_goal": { "type": "string" },
        "removed_obligations": { "type": "array", "items": { "type": "string" } },
        "kept_obligations": { "type": "array", "items": { "type": "string" } },
        "target_fidelity_preserved": { "type": "boolean" },
        "risk": { "type": "string" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "canonical_statement", "variables", "hypotheses", "definitions", "conclusion"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string", "enum": ["theorem", "lemma", "disproof", "reduction", "algorithm_correctness", "audit", "open_problem_progress"] },
        "original_problem": { "type": "string" },
        "canonical_statement": { "type": "string" },
        "variables": { "type": "array", "items": { "type": "string" } },
        "hypotheses": { "type": "array", "items": { "type": "string" } },
        "definitions": { "type": "array", "items": { "type": "string" } },
        "conclusion": { "type": "string" },
        "quantifier_order": { "type": "string" }
      }
    },
    "artifact_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_type", "statement", "status"],
      "properties": {
        "result_type": {
          "type": "string",
          "enum": ["full_theorem", "special_case", "bound", "conditional_theorem", "reduction", "obstruction", "counterexample", "computation", "failed_attempt", "conjecture", "lemma"]
        },
        "statement": { "type": "string" },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "known_gaps": { "type": "array", "items": { "type": "string" } },
        "relationship_to_original": { "type": "string" },
        "remaining_gap_statement": { "type": "string" },
        "why_not_full_solution": { "type": "string" },
        "known_result_comparison": { "type": "string" },
        "novelty_status": { "$ref": "#/$defs/novelty_status" },
        "next_exact_experiment_or_lemma": { "type": "string" },
        "closure_attempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/closure_attempt" }
        },
        "status": { "$ref": "#/$defs/status" }
      }
    },
    "sketches": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sketch" }
    },
    "selected_sketch_id": { "type": "string" },
    "obligation_graph": {
      "type": "array",
      "items": { "$ref": "#/$defs/obligation" }
    },
    "proof_dependency_dag": {
      "type": "array",
      "items": { "$ref": "#/$defs/proof_dependency_node" }
    },
    "worker_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/worker_result" }
    },
    "lovasz_barrier_attack": {
      "type": "object",
      "additionalProperties": true,
      "required": ["barriers_resolved", "barriers_still_open", "claim_statuses", "barrier_attack_records", "next_recommended_target"],
      "properties": {
        "barriers_resolved": { "type": "array", "items": { "type": "string" } },
        "barriers_still_open": { "type": "array", "items": { "type": "string" } },
        "claim_statuses": { "type": "array", "items": { "type": "string" } },
        "barrier_attack_records": { "type": "array", "items": { "$ref": "#/$defs/barrier_attack_record" } },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "counterexample_search_results": { "type": "array", "items": { "type": "string" } },
        "proof_gaps": { "type": "array", "items": { "type": "string" } },
        "next_recommended_target": { "type": "string" }
      }
    },
    "lovasz_dispatch_blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "attempted_actions", "next_unblock_action"],
      "properties": {
        "reason": { "type": "string" },
        "attempted_actions": { "type": "array", "items": { "type": "string" } },
        "next_unblock_action": { "type": "string" }
      }
    },
    "final_assembly_check": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dependencies_covered": { "type": "boolean" },
        "no_cycles": { "type": "boolean" },
        "no_hidden_assumptions": { "type": "boolean" },
        "target_hashes_match": { "type": "boolean" },
        "no_conjecture_used_as_theorem": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "proof_worktrees": {
      "type": "array",
      "items": { "$ref": "#/$defs/proof_worktree" }
    },
    "actual_lemma_queue": {
      "type": "array",
      "items": { "$ref": "#/$defs/actual_lemma_queue_item" }
    },
    "retry_ledger": {
      "type": "array",
      "items": { "$ref": "#/$defs/retry_ledger_entry" }
    },
    "skeptic_reviews": {
      "type": "array",
      "items": { "$ref": "#/$defs/skeptic_review" }
    },
    "final_synthesis_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_dag_edges_compose",
        "no_conjecture_used_as_theorem",
        "no_hidden_assumptions",
        "no_weaker_theorem_substituted",
        "external_preconditions_discharged",
        "target_hashes_match",
        "wit_lean_hashes_match"
      ],
      "properties": {
        "all_dag_edges_compose": { "type": "boolean" },
        "no_conjecture_used_as_theorem": { "type": "boolean" },
        "no_hidden_assumptions": { "type": "boolean" },
        "no_weaker_theorem_substituted": { "type": "boolean" },
        "external_preconditions_discharged": { "type": "boolean" },
        "target_hashes_match": { "type": "boolean" },
        "wit_lean_hashes_match": { "type": "boolean" },
        "auditor": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "generator_artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/generator_artifact" }
    },
    "external_facts": {
      "type": "array",
      "items": { "$ref": "#/$defs/external_fact" }
    },
    "external_verifications": {
      "type": "array",
      "items": { "$ref": "#/$defs/external_verification" }
    },
    "mutation_tracker": {
      "type": "array",
      "items": { "$ref": "#/$defs/mutation" }
    },
    "counterexamples_checked": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target_freeze": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_text_sha256", "canonical_target_sha256", "given_block_sha256", "claim_block_sha256", "definitions_sha256"],
      "properties": {
        "source_text_sha256": { "type": "string" },
        "canonical_target_sha256": { "type": "string" },
        "given_block_sha256": { "type": "string" },
        "claim_block_sha256": { "type": "string" },
        "definitions_sha256": { "type": "string" }
      }
    },
    "status": { "$ref": "#/$defs/status" },
    "lean_notes": { "type": "string" },
    "wit_notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": {
        "required": ["problem_status", "state", "task_kind"],
        "properties": {
          "problem_status": { "enum": ["OPEN", "UNSOLVED", "UNCONFIRMED"] },
          "state": { "const": "REPORT" },
          "task_kind": {
            "enum": ["prove", "disprove", "prove_or_disprove", "solve", "deep_research"]
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "required": ["proof_dependency_dag"],
            "properties": { "proof_dependency_dag": { "minItems": 1 } }
          },
          {
            "required": ["worker_results"],
            "properties": { "worker_results": { "minItems": 1 } }
          },
          { "required": ["lovasz_barrier_attack"] },
          { "required": ["lovasz_dispatch_blocker"] }
        ]
      }
    }
  ],
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["VERIFIED", "CHECKED", "PROVED_SKETCH", "UNVERIFIED", "OPEN", "PARTIAL", "CONDITIONAL", "CONJECTURE", "FAILED_ATTEMPT", "GAP", "REJECTED"]
    },
    "novelty_status": {
      "type": "string",
      "enum": ["new", "known", "variant", "unknown", "not_applicable"]
    },
    "closure_attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method_family", "attempt", "result", "remaining_blocker"],
      "properties": {
        "method_family": { "type": "string" },
        "attempt": { "type": "string" },
        "result": { "type": "string" },
        "remaining_blocker": { "type": "string" }
      }
    },
    "sketch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sketch_id",
        "target_theorem",
        "proof_strategy",
        "lemmas",
        "remaining_goals",
        "known_gaps",
        "status",
        "ev"
      ],
      "properties": {
        "sketch_id": { "type": "string" },
        "parent_sketch_id": { "type": ["string", "null"] },
        "target_theorem": { "type": "string" },
        "proof_strategy": { "type": "string" },
        "current_artifact": { "type": "string" },
        "proof_objects": { "type": "array", "items": { "type": "string" } },
        "lemmas": {
          "type": "array",
          "items": { "$ref": "#/$defs/lemma" }
        },
        "solved_pieces": { "type": "array", "items": { "type": "string" } },
        "remaining_goals": { "type": "array", "items": { "type": "string" } },
        "known_gaps": { "type": "array", "items": { "type": "string" } },
        "failure_class": { "type": "string" },
        "next_mutation": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "ev": {
          "type": "object",
          "additionalProperties": false,
          "required": ["theorem_fidelity", "probability_of_completion", "verifier_friendliness", "expected_value"],
          "properties": {
            "theorem_fidelity": { "type": "number", "minimum": 0, "maximum": 1 },
            "probability_of_completion": { "type": "number", "minimum": 0, "maximum": 1 },
            "verifier_friendliness": { "type": "number", "minimum": 0, "maximum": 1 },
            "expected_value": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "lemma": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "role", "inputs", "outputs", "dependencies", "proof_idea", "risk", "economics"],
      "properties": {
        "id": { "type": "string" },
        "statement": { "type": "string" },
        "role": { "type": "string" },
        "inputs": { "type": "array", "items": { "type": "string" } },
        "outputs": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "proof_idea": { "type": "string" },
        "risk": { "type": "string" },
        "automation_candidates": { "type": "array", "items": { "type": "string" } },
        "economics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["goals_unlocked", "proof_complexity", "lemma_value"],
          "properties": {
            "goals_unlocked": { "type": "number", "minimum": 0 },
            "proof_complexity": { "type": "number", "exclusiveMinimum": 0 },
            "lemma_value": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "backward_goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "would_follow_from"],
      "properties": {
        "goal": { "type": "string" },
        "would_follow_from": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["subgoal", "justification", "dependencies", "risk"],
            "properties": {
              "subgoal": { "type": "string" },
              "justification": { "type": "string" },
              "dependencies": { "type": "array", "items": { "type": "string" } },
              "risk": { "type": "string" }
            }
          }
        }
      }
    },
    "proof_dependency_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "type", "statement", "depends_on", "status"],
      "properties": {
        "node_id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["actual_barrier_lemma", "lemma", "reduction", "special_case", "obstruction", "counterexample_search", "computational_certificate", "conditional_theorem", "failed_method"]
        },
        "statement": { "type": "string" },
        "depends_on": { "type": "array", "items": { "type": "string" } },
        "attacks_barrier": { "type": "string" },
        "actual_barrier_lemma": { "type": "string" },
        "relation_to_frozen_target": { "type": "string" },
        "weaker_variant_justification": { "type": "string" },
        "direct_attack_count": { "type": "integer", "minimum": 0 },
        "counterexample_pressure": { "type": "string" },
        "theorem_precondition_gap": { "type": "string" },
        "next_exact_attempt": { "type": "string" },
        "remaining_gap_statement": { "type": "string" },
        "why_not_full_solution": { "type": "string" },
        "known_result_comparison": { "type": "string" },
        "novelty_status": { "$ref": "#/$defs/novelty_status" },
        "next_exact_experiment_or_lemma": { "type": "string" },
        "closure_attempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/closure_attempt" }
        },
        "target_fidelity": { "type": "number", "minimum": 0, "maximum": 1 },
        "skeptic_review_id": { "type": "string" },
        "subproblem_score": { "type": "number" },
        "status": { "$ref": "#/$defs/status" },
        "verification_evidence": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "wit_path": { "type": "string" },
            "lean_path": { "type": "string" },
            "wit_target_sha256": { "type": "string" },
            "lean_target_sha256": { "type": "string" },
            "frozen_target_sha256": { "type": "string" },
            "lean_status": { "type": "string" },
            "safeverify_status": { "type": "string" }
          }
        }
      }
    },
    "worker_result": {
      "type": "object",
      "additionalProperties": true,
      "required": ["worker_id", "status", "wit_path", "session_id", "proof_worktree", "proof_worktree_dedicated", "worktree_status"],
      "properties": {
        "worker_id": { "type": "string" },
        "node_id": { "type": "string" },
        "proof_id": { "type": "string" },
        "session_id": { "type": "string" },
        "proof_worktree": { "type": "string" },
        "proof_worktree_dedicated": { "type": "boolean" },
        "worktree_status": { "type": "string", "enum": ["created", "reused_dedicated", "preserved", "cleaned", "cleanup_failed"] },
        "target_fidelity": { "type": "number", "minimum": 0, "maximum": 1 },
        "skeptic_review_id": { "type": "string" },
        "wit_target_sha256": { "type": "string" },
        "lean_target_sha256": { "type": "string" },
        "frozen_target_sha256": { "type": "string" },
        "subproblem_statement": { "type": "string" },
        "wit_path": { "type": "string" },
        "lean_path": { "type": "string" },
        "lean_status": { "type": "string" },
        "safeverify_status": { "type": "string" },
        "remaining_gap_statement": { "type": "string" },
        "why_not_full_solution": { "type": "string" },
        "known_result_comparison": { "type": "string" },
        "novelty_status": { "$ref": "#/$defs/novelty_status" },
        "next_exact_experiment_or_lemma": { "type": "string" },
        "closure_attempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/closure_attempt" }
        },
        "created_lean_project": { "type": "boolean" },
        "cleanup_status": { "type": "string" },
        "status": { "$ref": "#/$defs/status" }
      }
    },
    "proof_worktree": {
      "type": "object",
      "additionalProperties": false,
