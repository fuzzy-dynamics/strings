{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WitsocExplorerHandoff",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "problem_class": {
          "type": "string",
          "enum": ["SOLVED_RECONSTRUCTION", "OPEN_RESEARCH_SUBGOAL"]
        }
      },
      "required": ["task_id", "problem_class"]
    },
    "target_formalization": {
      "description": "The exact, frozen mathematical boundaries. No silent drift allowed.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "domains_and_variables": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "definitions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "hypotheses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "claim": { "type": "string", "minLength": 1 }
      },
      "required": ["domains_and_variables", "definitions", "hypotheses", "claim"]
    },
    "epistemic_context": {
      "description": "The surrounding landscape, enforcing Barrier and Triage protocols.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "known_barriers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "For open problems: why naive approaches fail."
        },
        "degeneracy_checks_passed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Evidence that boundary cases were verified."
        }
      },
      "required": ["known_barriers", "degeneracy_checks_passed"]
    },
    "external_dependencies": {
      "description": "Strict ledger of non-local theorems to be invoked.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "theorem_name": { "type": "string", "minLength": 1 },
          "exact_statement": { "type": "string", "minLength": 1 },
          "required_preconditions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "formal_availability_target": {
            "type": "string",
            "minLength": 1,
            "description": "e.g. Mathlib4 top-level or Requires Local Weakening"
          }
        },
        "required": [
          "theorem_name",
          "exact_statement",
          "required_preconditions",
          "formal_availability_target"
        ]
      }
    },
    "lemma_plan": {
      "description": "The directed acyclic graph (DAG) of the proof strategy.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["ASSUME", "HAVE", "CASE_SPLIT", "SHOW"]
          },
          "statement": { "type": "string", "minLength": 1 },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "method": {
            "type": "string",
            "minLength": 1,
            "description": "Exact tactic, definition unfolding, local lemma, or external theorem."
          }
        },
        "required": ["step_id", "type", "statement", "depends_on", "method"]
      }
    },
    "generator_directive": {
      "description": "What exactly the Generator is supposed to write.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifact_target": {
          "type": "string",
          "enum": ["FULL_PROOF", "CONDITIONAL_THEOREM", "OBSTRUCTION_LEMMA", "COUNTEREXAMPLE"]
        },
        "status_to_assert": {
          "type": "string",
          "enum": ["UNVERIFIED", "PARTIAL", "CONDITIONAL", "GAP"]
        }
      },
      "required": ["artifact_target", "status_to_assert"]
    }
  },
  "required": [
    "metadata",
    "target_formalization",
    "epistemic_context",
    "external_dependencies",
    "lemma_plan",
    "generator_directive"
  ]
}
