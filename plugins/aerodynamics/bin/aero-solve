#!/usr/bin/env bash
# Solve a flow case via the running plugin server and print the JSON result.
# Useful for agents that want streamline data without touching the iframe.

set -euo pipefail

BODY="${1:-teardrop}"
N="${2:-80}"
ROWS="${3:-5}"
U="${4:-1.0}"

PLANE="${PLANE_SERVER_URL:-http://127.0.0.1:5495}"
PORT="$(curl -sf "$PLANE/plugins/aerodynamics/status" \
  | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("port") or "")' 2>/dev/null)"

if [[ -z "$PORT" ]]; then
  echo "[aero-solve] aerodynamics server not running. Run: \"\$PLANE_TOOL_BIN\" plugins activate aerodynamics" >&2
  exit 2
fi

curl -fSL "http://127.0.0.1:$PORT/api/solve?body=$BODY&n=$N&yRows=$ROWS&U=$U"
