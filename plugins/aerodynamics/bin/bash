#!/usr/bin/env bash
set -euo pipefail
PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"

cmd="${1:-help}"
shift || true

case "$cmd" in
  info)
    echo "plugin_dir : $PLUGIN_DIR"
    if [[ -f "$PLUGIN_DIR/ui/vendor/three.min.js" ]]; then
      echo "three.js   : bundled"
    else
      echo "three.js   : not downloaded (run 'plugins activate aerodynamics')"
    fi
    echo
    echo "Server status: \"\$PLANE_TOOL_BIN\" plugins status aerodynamics"
    ;;
  solve)
    "$PLUGIN_DIR/bin/aero-solve" "$@"
    ;;
  help|--help|-h|"")
    cat <<'EOF'
plugins bash aerodynamics <subcommand> [args]

Subcommands:
  info                                   Show install info
  solve [body] [n] [rows] [U]            Run solver, print JSON
                                         body : teardrop | sphere | ellipsoid (default teardrop)
                                         n    : streamlines per row (default 80)
                                         rows : vertical rows (default 5)
                                         U    : free-stream speed (default 1.0)
  help                                   This message

Examples:
  plugins bash aerodynamics info
  plugins bash aerodynamics solve teardrop 80 5
  plugins bash aerodynamics solve sphere 60 8 1.5
EOF
    ;;
  *)
    echo "[aerodynamics] unknown subcommand: $cmd" >&2
    exit 2
    ;;
esac
