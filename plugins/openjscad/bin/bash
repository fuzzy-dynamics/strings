#!/usr/bin/env bash
# `plugins bash openjscad <subcommand>` dispatcher.

set -euo pipefail

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
NODE_MODULES="$PLUGIN_DIR/data/node_modules"

cmd="${1:-help}"
shift || true

case "$cmd" in
  info)
    echo "plugin_dir   : $PLUGIN_DIR"
    echo "node_modules : $NODE_MODULES"
    if [[ -d "$NODE_MODULES/@jscad/modeling" ]]; then
      ver=$(node -e "console.log(require('$NODE_MODULES/@jscad/modeling/package.json').version)" 2>/dev/null || echo '?')
      echo "modeling     : $ver"
    else
      echo "modeling     : not installed (run 'plugins activate openjscad')"
    fi
    if [[ -f "$PLUGIN_DIR/ui/vendor/three.min.js" ]]; then
      echo "three.js     : bundled"
    else
      echo "three.js     : not downloaded (run 'plugins activate openjscad')"
    fi
    echo
    echo "Server status: \"\$PLANE_TOOL_BIN\" plugins status openjscad"
    ;;
  list)
    "$PLUGIN_DIR/bin/jscad-list" "$@"
    ;;
  render)
    "$PLUGIN_DIR/bin/jscad-render" "$@"
    ;;
  help|--help|-h|"")
    cat <<'EOF'
plugins bash openjscad <subcommand> [args]

Subcommands:
  info                          Show install + dep versions
  list [dir]                    Find .jscad files under dir (default $KIMI_WORK_DIR)
  render <in.jscad> [out.stl]   Render to STL via the running server
  help                          This message

Examples:
  plugins bash openjscad info
  plugins bash openjscad list
  plugins bash openjscad render shapes.jscad
EOF
    ;;
  *)
    echo "[openjscad] unknown subcommand: $cmd" >&2
    echo "Run: plugins bash openjscad help" >&2
    exit 2
    ;;
esac
