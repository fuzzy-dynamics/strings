#!/usr/bin/env bash
# openjscad plugin server bootstrap.
#
# plane-server lifecycle exec()s this with $PORT, $PLUGIN_ID, $PLUGIN_DATA_DIR
# in env. We ensure deps are present, then exec the Node server.

set -euo pipefail

if [[ -z "${PORT:-}" ]]; then
  echo "[openjscad] PORT env not set — refusing to start" >&2
  exit 2
fi

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
"$PLUGIN_DIR/bin/ensure-deps"

exec node "$PLUGIN_DIR/server/index.js"
