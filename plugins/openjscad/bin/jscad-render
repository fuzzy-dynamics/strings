#!/usr/bin/env bash
# Render a .jscad file to STL via the running plugin server.
#
# Usage:  jscad-render <input.jscad> [output.stl]
#
# Requires the server to be running (plugins activate openjscad).

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: jscad-render <input.jscad> [output.stl]" >&2
  exit 2
fi

IN="$1"
OUT="${2:-${IN%.jscad}.stl}"

if [[ ! -f "$IN" ]]; then
  echo "[jscad-render] file not found: $IN" >&2; exit 2
fi
IN_ABS="$(cd "$(dirname "$IN")" && pwd)/$(basename "$IN")"

# Resolve the plugin's port from plane-server's status endpoint.
PLANE="${PLANE_SERVER_URL:-http://127.0.0.1:5495}"
PORT="$(curl -sf "$PLANE/plugins/openjscad/status" \
  | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("port") or "")' 2>/dev/null)"

if [[ -z "$PORT" ]]; then
  echo "[jscad-render] openjscad server not running. Run: \"\$PLANE_TOOL_BIN\" plugins activate openjscad" >&2
  exit 2
fi

ENCODED=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$IN_ABS")
curl -fSL "http://127.0.0.1:$PORT/api/render?path=$ENCODED" -o "$OUT"
echo "$OUT"
