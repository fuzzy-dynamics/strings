#!/usr/bin/env bash
# hello-world plugin: bin/hello
# Prints a greeting and the runtime context the plugin was launched in.

set -euo pipefail

NAME="${1:-world}"
PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"

echo "Hello, ${NAME}!"
echo "  plugin_dir         = ${PLUGIN_DIR}"
echo "  plane_session_dir  = ${PLANE_SESSION_DIR:-<unset>}"
echo "  plane_session_id   = ${PLANE_SESSION_ID:-<unset>}"
echo "  kimi_work_dir      = ${KIMI_WORK_DIR:-<unset>}"
