#!/usr/bin/env bash
# witsoc plugin server bootstrap. Ensures the venv exists, then exec's the
# Node HTTP fronter.

set -euo pipefail

if [[ -z "${PORT:-}" ]]; then
  echo "[witsoc] PORT env not set — refusing to start" >&2
  exit 2
fi

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
"$PLUGIN_DIR/bin/ensure-deps"

# Pass the venv path through so server/index.js doesn't have to re-derive.
export WITSOC_VENV="$PLUGIN_DIR/data/venv"
exec node "$PLUGIN_DIR/server/index.js"
