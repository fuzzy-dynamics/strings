#!/usr/bin/env bash
# Scaffold a new .wit skeleton.
#
# Usage:  wit-new <name> [target-dir]
#         wit-new grover_constant tests/

set -euo pipefail

NAME="${1:?Usage: wit-new <name> [dir]}"
NAME="${NAME%.wit}"
TARGET_DIR="${2:-${KIMI_WORK_DIR:-$PWD}}"
TARGET_FILE="${TARGET_DIR%/}/${NAME}.wit"

mkdir -p "$TARGET_DIR"

if [[ -e "$TARGET_FILE" ]]; then
  echo "[wit-new] already exists: $TARGET_FILE" >&2
  exit 1
fi

cat > "$TARGET_FILE" <<EOF
-- Status: UNVERIFIED
-- Author: $(whoami)
-- Created: $(date +%Y-%m-%d)

MODULE ${NAME}

THEOREM ${NAME}:
  GIVEN:
    -- Hypotheses go here.
  CLAIM:
    -- The claim, as a single mathematical statement.

PROOF OF ${NAME}:
  [1] HAVE -- first established fact
      BY -- citation or "definition", "algebra", etc.

  [2] SHOW -- the theorem's claim
      BY [1].

  QED BY [2].
EOF

echo "$TARGET_FILE"
