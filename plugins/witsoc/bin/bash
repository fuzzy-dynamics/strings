#!/usr/bin/env bash
# `plugins bash witsoc <subcommand>` dispatcher. Each subcommand wraps a
# witsoc CLI verb, plus a few helpers for the soc working-memory format.

set -euo pipefail

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
WIT="$PLUGIN_DIR/data/venv/bin/wit"

ensure_venv() {
  if [[ ! -x "$WIT" ]]; then
    "$PLUGIN_DIR/bin/ensure-deps"
  fi
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  info)
    ensure_venv
    echo "plugin_dir : $PLUGIN_DIR"
    echo "venv       : $PLUGIN_DIR/data/venv"
    echo "wit        : $WIT"
    "$WIT" --version 2>/dev/null | head -1 || echo "wit binary not found"
    ;;
  list)      "$PLUGIN_DIR/bin/wit-list" "$@";;
  new)       "$PLUGIN_DIR/bin/wit-new"  "$@";;
  status)
    if [[ $# -lt 1 ]]; then echo "Usage: status <file.wit>" >&2; exit 2; fi
    grep -m1 -E '^-- Status:' "$1" 2>/dev/null || echo "-- Status: UNVERIFIED"
    ;;
  check)     ensure_venv; exec "$WIT" check "$@";;
  verify)    ensure_venv; exec "$WIT" verify "$@";;
  context)   ensure_venv; exec "$WIT" context "$@";;
  receipt)   ensure_venv; exec "$WIT" receipt "$@";;

  # ─── Soc working memory helpers ────────────────────────────────────
  soc-init)
    target="${1:-${KIMI_WORK_DIR:-$PWD}/research.soc}"
    if [[ -e "$target" ]]; then echo "[witsoc] already exists: $target" >&2; exit 1; fi
    cat > "$target" <<'EOF'
# Soc Working Memory

GOAL: <one-line statement of the overall goal>

PROGRESS: 0 / 0
INSIGHTS_SINCE_LAST_UPDATE: 0

QUEUE:
  - [ ] First sub-problem to attack

INSIGHTS:
  - (none yet)

LOG:
  -
EOF
    echo "$target"
    ;;
  soc-show)
    target="${1:-${KIMI_WORK_DIR:-$PWD}/research.soc}"
    [[ -f "$target" ]] || { echo "[witsoc] no .soc file at $target" >&2; exit 2; }
    cat "$target"
    ;;

  help|--help|-h|"")
    cat <<'EOF'
plugins bash witsoc <subcommand> [args]

Read-only / informational
  info                              venv path + wit version
  list [dir]                        find .wit files (default $KIMI_WORK_DIR)
  status <file.wit>                 read the "-- Status:" header

Authoring
  new <name> [dir]                  create a .wit skeleton

Wit pipeline (the prover-verifier loop)
  check <file.wit>                  structural validation
  verify <file.wit> [--step N.M]    build LLM-ready verification contexts
  context <file.wit>                debug: dump exactly what verifier sees
  receipt <file.wit>                read verifier verdicts from stdin → .receipt.json

Soc working memory
  soc-init [path]                   scaffold a fresh .soc file
  soc-show [path]                   print the .soc file

  help                              this message

Examples
  plugins bash witsoc list
  plugins bash witsoc new grover_constant
  plugins bash witsoc check tests/grover_constant.wit
  plugins bash witsoc verify tests/grover_constant.wit --step 3.1
  llm-output | plugins bash witsoc receipt tests/grover_constant.wit
EOF
    ;;
  *)
    echo "[witsoc] unknown subcommand: $cmd" >&2
    echo "Run: plugins bash witsoc help" >&2
    exit 2
    ;;
esac
